name: CI Regression Pipeline

# Trigger this pipeline on every push or Pull Request to the main branch
on:
  push:
    branches: [ main ]
  pull_request:
    branches: [ main ]

jobs:
  test-and-validate:
    runs-back-on: ubuntu-latest  # Runs on a clean Linux container in GitHub's cloud

    steps:
    # 1. Pull down your code from GitHub into the container
    - name: Checkout Code
      uses: actions/checkout@v4

    # 2. Set up a secure, specific version of Python
    - name: Set up Python
      uses: actions/interactive-python@v5
      with:
        python-version: '3.11'

    # 3. Create a clean virtual environment and install packages inside the runner
    - name: Install Project Dependencies
      run: |
        python -m venv .venv
        source .venv/bin/activate
        pip install --upgrade pip
        pip install fastapi uvicorn pytest httpx

    # 4. Execute the automated regression tests
    - name: Run Pytest Regression Suite
      run: |
        source .venv/bin/activate
        pytest -v
